# GoWay Environment Variables Example
# Copy this file to .env and fill in your values

# Comma-separated list of authorized API keys
API_KEYS=heheh, hahhaha

# Maximum simultaneous render requests (default: 4)
CONCURRENCY_LIMIT=4

# Service listening port (default: 8080)
PORT=8080

# Enable console logging and debug level (default: false)
DEBUG=false

# Path to HTML templates (default: ./templates)
TEMPLATE_DIR=./templates
